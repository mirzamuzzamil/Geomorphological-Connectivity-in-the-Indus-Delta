\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{copernicus}[2026/06/05 Standard Copernicus Publications Class Wrapper]

% Inherit from standard article class
\LoadClass[11pt,a4paper]{article}

% Load packages needed for HESS style
\RequirePackage[utf8]{inputenc}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{graphicx}
\RequirePackage{natbib}
\RequirePackage{hyperref}
\RequirePackage{booktabs}
\RequirePackage{geometry}
\RequirePackage{setspace}

\geometry{verbose,tmargin=2.5cm,bmargin=2.5cm,lmargin=2.5cm,rmargin=2.5cm}
\doublespacing

% Mock Copernicus specific commands
\gdef\@runningtitle{}
\gdef\@runningauthor{}
\gdef\@correspondence{}
\gdef\@received{}
\gdef\@pubdiscuss{}
\gdef\@accepted{}
\gdef\@published{}
\gdef\@firstpage{}

\newcommand{\runningtitle}[1]{\gdef\@runningtitle{#1}}
\newcommand{\runningauthor}[1]{\gdef\@runningauthor{#1}}
\newcommand{\correspondence}[1]{\gdef\@correspondence{#1}}
\newcommand{\received}[1]{\gdef\@received{#1}}
\newcommand{\pubdiscuss}[1]{\gdef\@pubdiscuss{#1}}
\newcommand{\accepted}[1]{\gdef\@accepted{#1}}
\newcommand{\published}[1]{\gdef\@published{#1}}
\newcommand{\firstpage}[1]{\gdef\@firstpage{#1}}

% Copernicus section macros
\newcommand{\introduction}{\section{Introduction}}
\newcommand{\codeavailability}{\section*{Code availability}}
\newcommand{\dataavailability}{\section*{Data availability}}
\newcommand{\authorcontribution}{\section*{Author contributions}}
\newcommand{\competinginterests}{\section*{Competing interests}}
\newcommand{\disclaimer}{\section*{Disclaimer}}
\newcommand{\acknowledgements}{\section*{Acknowledgements}}
\newcommand{\supplementlink}{\section*{Supplement}}



% Mock author affiliation commands
\gdef\@author{}
\renewcommand{\author}[2][]{%
  \ifx\@author\empty
    \gdef\@author{#2\textsuperscript{#1}}%
  \else
    \gdef\@author{\@author, #2\textsuperscript{#1}}%
  \fi
}

\gdef\@affil{}
\newcommand{\affil}[2][]{%
  \ifx\@affil\empty
    \gdef\@affil{\textsuperscript{#1}#2}%
  \else
    \gdef\@affil{\@affil\\ \textsuperscript{#1}#2}%
  \fi
}

\renewcommand{\maketitle}{%
  \begin{center}
    \singlespacing
    {\LARGE\bfseries \@title \par}
    \vskip 1.5em
    {\large \@author \par}
    \vskip 1.0em
    {\small \itshape \@affil \par}
    \vskip 1.0em
    {\small \@correspondence \par}
    \vskip 1.0em
    {\small \itshape Received: \@received\ -- Published: \@published\ -- Accepted: \@accepted \par}
    \vskip 1.5em
  \end{center}
  \vskip 1.5em
}

% Set up bibliography style
\bibliographystyle{plainnat}

\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  citecolor=blue,
  urlcolor=blue
}
