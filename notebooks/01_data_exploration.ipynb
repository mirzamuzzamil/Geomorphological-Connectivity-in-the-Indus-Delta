  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 01. Data Exploration — Indus Delta Surface Water Dynamics\n",
    "\n",
    "This notebook provides an interactive walkthrough to load, explore, and analyze the dataset used in the paper: **\"Geomorphological Connectivity and Temporal Hydrological Controls of Surface Water Dynamics in the Indus River Delta\"**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import os\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Check dataset path\n",
    "dataset_path = '../data/indus_dataset_sample.npz'\n",
    "if not os.path.exists(dataset_path):\n",
    "    dataset_path = '../data/indus_dataset.npz'\n",
    "\n",
    "print(f\"Loading dataset: {dataset_path}\")\n",
    "data = np.load(dataset_path)\n",
    "X = data['X']\n",
    "y = data['y']\n",
    "\n",
    "print(f\"Features shape: {X.shape}\")\n",
    "print(f"Labels shape:   {y.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Feature Columns Mapping\n",
    "\n",
    "Depending on the dataset version (`indus_dataset` vs `indus_dataset_v2` / `indus_dataset_sample`):"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if X.shape[1] == 11:\n",
    "    feature_names = [\n",
    "        \"precipitation\", \"temperature\", \"evaporation\", \"potential_evaporation\",\n",
    "        \"elevation\", \"slope\", \"flow_accumulation\", \"dist_to_river\", \"dist_to_coast\",\n",
    "        \"year\", \"month\"\n",
    "    ]\n",
    "else:\n",
    "    feature_names = [\n",
    "        \"NDVI\", \"NDWI\", \"MNDWI\", \"LSWI\", \"VV\", \"VH\", \"VH_VV_ratio\",\n",
    "        \"precipitation\", \"temperature\", \"evaporation\", \"potential_evaporation\",\n",
    "        \"elevation\", \"slope\", \"flow_accumulation\", \"dist_to_river\", \"dist_to_coast\",\n",
    "        \"year\", \"month\"\n",
    "    ]\n",
    "\n",
    "print(\"Feature layout:\")\n",
    "for idx, name in enumerate(feature_names):\n",
    "    print(f\"  Column {idx}: {name}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Surface Inundation Distribution (Class Balance)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "total_samples = len(y)\n",
    "water_count = np.sum(y == 1)\n",
    "land_count = np.sum(y == 0)\n",
    "\n",
    "print(f\"Total Observations: {total_samples}\")\n",
    "print(f\"Water Pixels:      {water_count} ({water_count/total_samples:.2%})\")\n",
    "print(f\"Land Pixels:       {land_count} ({land_count/total_samples:.2%})\")\n",
    "\n",
    "# Plot pie chart\n",
    "plt.figure(figsize=(5, 5))\n",
    "plt.pie([land_count, water_count], labels=['Land (0)', 'Water (1)'], colors=['#e2e8f0', '#2166ac'], autopct='%1.1f%%', startangle=140)\n",
    "plt.title('Indus Delta Surface Water Occurrence')\n",
    "plt.show()"
   ]
  }
 ],
